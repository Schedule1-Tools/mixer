{
  "name": "@schedule1-tools/mixer",
  "version": "0.3.1",
  "description": "A package for calculating substance mixes in Schedule 1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun jest",
    "test:coverage": "bun jest --coverage",
    "prepublishOnly": "bun run test && bun run build",
    "format": "prettier --write ."
  },
  "keywords": [
    "schedule1"
  ],
  "author": "Schedule1 Tools",
  "license": "MIT",
  "dependencies": {
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "^1.3.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/schedule1-tools/mixer.git"
  },
  "bugs": {
    "url": "https://github.com/schedule1-tools/mixer/issues"
  },
  "homepage": "https://github.com/schedule1-tools/mixer#readme"
}
